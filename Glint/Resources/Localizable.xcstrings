            "value": "Glint"
          }
        }
      }
    },
    "Glint auto-installs a reporter into ~/.claude/settings.json on launch. Existing hooks are preserved.": {
      "extractionState": "stale",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Glint 启动时会自动把上报脚本合并进 ~/.claude/settings.json,已有 hook 会被保留。"
          }
        }
      }
    },
    "Glint can register a small hook with Claude Code (~/.claude/settings.json) and Codex (~/.codex/hooks.json) that reports when an agent is thinking, finished, or waiting for approval. It only sends events to Glint on this Mac. You can uninstall it anytime in Settings → Agents.": {
      "extractionState": "manual",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Glint 可以向 Claude Code(~/.claude/settings.json)和 Codex(~/.codex/hooks.json)注册一个小 hook,上报 agent 正在思考、已完成或等待批准的状态。事件只会发送给这台 Mac 上的 Glint,随时可在 设置 → Agents 中卸载。"
          }
        }
      }
    },
    "Glint is dark-mode only for now.": {
      "extractionState": "stale",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Glint 目前仅支持深色模式。"
          }
        }
      }
    },
    "Glint uses Sparkle to check the GitHub Releases feed and install updates in place.": {
      "extractionState": "stale",
      "localizations": {
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
